{
  "name": "cerebrexia-backend",
  "version": "1.0.0",
  "description": "Cerebrexia Event Management Platform - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate": "node -r ts-node/register src/database/migrate.ts",
    "migrate:rollback": "node -r ts-node/register src/database/rollback.ts",
    "seed": "node -r ts-node/register src/database/seed.ts"
  },
  "keywords": [
    "event-management",
    "qr-code",
    "payment",
    "razorpay"
  ],
  "author": "Cerebrexia Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "typescript": "^5.3.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "google-auth-library": "^9.4.1",
    "razorpay": "^2.9.2",
    "qrcode": "^1.5.3",
    "nodemailer": "^6.9.7",
    "mjml": "^4.14.1",
    "pg": "^8.11.3",
    "redis": "^4.6.11",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "joi": "^17.11.0",
    "winston": "^3.11.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "multer": "^1.4.5-lts.1",
    "dotenv": "^16.3.1",
    "express-session": "^1.17.3",
    "connect-redis": "^7.1.0",
    "uuid": "^9.0.1",
    "date-fns": "^3.0.6",
    "node-cron": "^3.0.3",
    "bull": "^4.12.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.11",
    "@types/express-session": "^1.17.10",
    "@types/uuid": "^9.0.7",
    "@types/node-cron": "^3.0.11",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "@types/jest": "^29.5.11",
    "@types/supertest": "^6.0.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}